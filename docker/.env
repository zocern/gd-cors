# ============================================
# gd-cors Docker Compose 环境变量配置模板
# ============================================
# 说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 修改 .env 文件中的配置值
# 3. 修改后重新启动服务：docker-compose down && docker-compose up -d
# 4. .env 文件已在 .gitignore 中排除，不会提交到代码仓库
# ============================================

# ============================================
# 基础配置
# ============================================
# 时区配置（所有服务共用）
TZ=Asia/Shanghai

# ============================================
# 存储路径配置
# ============================================
# 所有数据存储的根路径前缀
# 默认值：/data/gd-cors
# 生产环境使用独立数据盘，如 /data-disk/gd-cors
STORAGE_PATH_1="/home/gdcors/dk/data-disk/gd-cors"
#STORAGE_PATH_2="/Volumes/WD_BLACK SN7100/gd-cors"
#STORAGE_PATH_3="/Volumes/WD_BLACK SN7100/gd-cors"
#STORAGE_PATH_4="/Volumes/WD_BLACK SN7100/gd-cors"

# ============================================
# MySQL 配置
# ============================================
# MySQL root 用户密码
MYSQL_ROOT_PASSWORD=root

# MySQL 数据库名称
MYSQL_DATABASE=gd_cors

# ============================================
# RabbitMQ 配置
# ============================================
# RabbitMQ 默认用户名
RABBITMQ_DEFAULT_USER=rabbitmq

# RabbitMQ 默认密码
RABBITMQ_DEFAULT_PASS=rabbitmq
RABBITMQ_DEFAULT_VHOST=/gd-cors

# ============================================
# Redis 配置
# ============================================
REDIS_ROOT_PASSWORD=redis
REDIS_MAXMEMORY=2048mb
REDIS_POLICY=volatile-lru

# ============================================
# minIO 配置
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_EMBEDDINGS=gd-cors-milvus

# ============================================
# 应用服务配置
# ============================================

# ==========================
# Web 配置
# ==========================
WEB_PORT=80

# ==========================
# Server 配置
# ==========================
SERVER_PORT=8080
APP1_HOST_PORT=8081
APP2_HOST_PORT=8082
SERVER_SERVLET_CONTEXT_PATH=/api/v1
SPRING_PROFILES_ACTIVE=dev
SERVLET_MULTIPART_MAX_FILE_SIZE=1073741824
SERVLET_MULTIPART_MAX_REQUEST_SIZE=1073741824

# ==========================
# Redis 配置
# ==========================
REDIS_HOST=gd-cors-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_DATABASE=0
REDIS_CONNECT_TIMEOUT=10000

# ==========================
# MySQL 配置
# ==========================
DATASOURCE_HOST=gd-cors-mysql
DATASOURCE_PORT=3306
DATASOURCE_DATABASE=gd_cors
DATASOURCE_USERNAME=root
DATASOURCE_PASSWORD=root
SQL_INIT_MODE=embedded
THREAD_POOL_CORE_SIZE=30
# ==========================
# RabbitMQ 配置
# ==========================
RABBITMQ_HOST=gd-cors-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=rabbitmq
RABBITMQ_PASSWORD=rabbitmq
RABBITMQ_VIRTUAL_HOST=/gd-cors
RABBITMQ_CONSUMER_CONCURRENCY=5
RABBITMQ_CONSUMER_MAX_CONCURRENCY=10
RABBITMQ_CONSUMER_PREFETCH=1

# ==========================
# LangChain4j 配置
# ==========================

LANGCHAIN4J_OPENAI_ONLINE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LANGCHAIN4J_OPENAI_ONLINE_MODEL_NAME=glm-4-plus
LANGCHAIN4J_OPENAI_ONLINE_MODEL_ZHIPU_API_KEY=
LANGCHAIN4J_OPENAI_ONLINE_LOG_REQUESTS=true
LANGCHAIN4J_OPENAI_ONLINE_LOG_RESPONSES=false
LANGCHAIN4J_OPENAI_ONLINE_TIMEOUT=120s

LANGCHAIN4J_OLLAMA_CHAT_BASE_URL=http://host.docker.internal:11434
LANGCHAIN4J_OLLAMA_CHAT_MODEL_NAME=qwen3:32b
LANGCHAIN4J_OLLAMA_CHAT_LOG_REQUESTS=true
LANGCHAIN4J_OLLAMA_CHAT_LOG_RESPONSES=false
LANGCHAIN4J_OLLAMA_CHAT_TIMEOUT=120s

LANGCHAIN4J_OLLAMA_VL_BASE_URL=http://host.docker.internal:11435
LANGCHAIN4J_OLLAMA_VL_MODEL_NAME=qwen3-vl:8b
LANGCHAIN4J_OLLAMA_VL_TEMPERATURE=0.1
LANGCHAIN4J_OLLAMA_VL_LOG_REQUESTS=true
LANGCHAIN4J_OLLAMA_VL_LOG_RESPONSES=false
LANGCHAIN4J_OLLAMA_VL_TIMEOUT=120s
LANGCHAIN4J_OLLAMA_VL_MAX_RETRIES=3

LANGCHAIN4J_OLLAMA_EMBEDDING_BASE_URL=http://host.docker.internal:11436
LANGCHAIN4J_OLLAMA_EMBEDDING_MODEL_NAME=qwen3-embedding:0.6b
LANGCHAIN4J_OLLAMA_EMBEDDING_LOG_REQUESTS=true
LANGCHAIN4J_OLLAMA_EMBEDDING_LOG_RESPONSES=false
LANGCHAIN4J_OLLAMA_EMBEDDING_TIMEOUT=120s
LANGCHAIN4J_OLLAMA_EMBEDDING_MAX_RETRIES=3

RERANKER_BASE_URL=http://gd-cors-tei-reranker:11438

LANGCHAIN4J_CHAT_MEMORY_MAX_MESSAGES=50

LANGCHAIN4J_WEB_SEARCH_ENGINE_TAVILY_MCP_SERVER_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=
LANGCHAIN4J_TAVILY_API_KEY=
LANGCHAIN4J_WEB_SEARCH_ENGINE_TAVILY_MAX_RESULTS=5

# ==========================
# Milvus 配置
# ==========================
MILVUS_HOST=gd-cors-milvus
MILVUS_PORT=19530
MILVUS_TOKEN=milvus-token
MILVUS_DATABASE=gd_cors
MILVUS_COLLECTION=text_embeddings
MILVUS_DIMENSION=1024

# ==========================
# MinIO 配置
# ==========================
MINIO_ENDPOINT=http://gd-cors-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FILES=gd-cors-files

# ==========================
# 用户 & JWT 配置
# ==========================
USER_PASSWORD_LENGTH=6
JWT_ACCESS_EXPIRE=7200000
JWT_REFRESH_EXPIRE=2592000000
JWT_SECURITY=cors

# ==========================
# 文件系统配置
# ==========================
RUN_ON_STARTUP=false
LOCAL_PATHS=""
PARENT_ID=0
