<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cors.mapper.FileVectorStatusMapper">

    <select id="selectStatusWithFile" resultType="com.cors.domain.vo.FileVectorStatusVo">
        SELECT
        f.id,
        f.name,
        f.size,
        v.storage_key,
        v.status,
        v.created,
        v.updated,
        v.retry_count,
        v.error_msg
        FROM file_vector_status v
        LEFT JOIN file_metadata f
        ON v.storage_key = f.storage_key
        <where>
            <if test="status != null">
                v.status = #{status}
            </if>
            <if test="keyword != null and keyword != ''">
                AND f.name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <!-- 添加时间范围查询条件 -->
            <if test="start != null">
                AND v.created &gt;= #{start}
            </if>
            <if test="end != null">
                AND v.created &lt; #{end}
            </if>
        </where>
        ORDER BY v.created DESC
    </select>

</mapper>

