<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cors.mapper.FileTagRelationMapper">

    <!-- 批量插入文件标签关联（忽略重复） -->
    <insert id="insertBatchIgnore">
        INSERT IGNORE INTO file_tag_relation (file_id, tag_id)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.fileId}, #{item.tagId})
        </foreach>
    </insert>

    <!-- 查询某文件绑定的所有标签ID -->
    <select id="selectTagIdsByFileId" parameterType="long" resultType="long">
        SELECT tag_id
        FROM file_tag_relation
        WHERE file_id = #{fileId}
    </select>

</mapper>
